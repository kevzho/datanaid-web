# ─────────────────────────────────────────────────────────────
# Datanaid — Environment Variables
# Copy this file to `.env.local` for local development.
# In production, set these in your Vercel project settings.
# ─────────────────────────────────────────────────────────────

# Vercel Blob — persistence (uploaded datasets, generated reports, anonymous usage events)
# Create a Blob store in the Vercel dashboard (Storage → Blob) and copy the token.
# Required for upload/report persistence in production. Anonymous usage events
# fall back to server logs when this is unset. Locally, Vercel CLI can also
# inject this via `vercel env pull`.
BLOB_READ_WRITE_TOKEN=

# ─────────────────────────────────────────────────────────────
# AI Insight Engine (OPTIONAL — hybrid mode)
# The insight engine is deterministic by default and works with NO API key.
# If you provide a key, insights are *rephrased* into polished prose, strictly
# constrained to the computed statistics (no new facts, no hallucinations).
# Without a key, Datanaid uses high-quality deterministic templates.
# ─────────────────────────────────────────────────────────────
GROQ_API_KEY=
# Model used for phrasing only. Default: llama-3.1-8b-instant
# This workload is constrained JSON rephrasing, so the 8B model is the default
# for lower latency and better free-tier headroom.
GROQ_PHRASING_MODEL=llama-3.1-8b-instant
GROQ_PHRASING_MAX_TOKENS=220

# ─────────────────────────────────────────────────────────────
# Python forecast microservice (OPTIONAL)
# The TypeScript engine ships a linear forecast with confidence intervals that
# works out of the box. This URL is only needed if you host a separate heavier
# Python forecasting service outside this Vercel app.
# ─────────────────────────────────────────────────────────────
PYTHON_ML_URL=
